# Copy to .env.local to enable analytics.
# All analytics are disabled unless these are filled in.

# --- Plausible (recommended) ---
# VITE_PLAUSIBLE_DOMAIN=nnt25.net
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js
